<script>
function price_format(n){
	c = {{ currency['decimals'] is defined and currency['decimals'] is not empty ? currency['decimals'] : "0" }};
	d = '{{ currency['decimal_point'] is defined ? currency['decimal_point'] : "." }}';
	t = '{{ currency['thousand_point'] is defined ? currency['thousand_point'] : "" }}';
	s_left = '{{ currency['symbol_left'] is defined ? currency['symbol_left'] : "" }}';
	s_right = '{{ currency['symbol_right'] is defined ? currency['symbol_right'] : "" }}';
	n = n * {{ currency['value'] is defined and currency['value'] is not empty ? currency['value'] : "1" }};
	i = parseInt(n = Math.abs(n).toFixed(c)) + '';
	j = ((j = i.length) > 3) ? j % 3 : 0;
	return s_left + (j ? i.substr(0, j) + t : '') + i.substr(j).replace(/(\d{3})(?=\d)/g, "$1" + t) + (c ? d + Math.abs(n - i).toFixed(c).slice(2) : '') + s_right;
}
</script>
