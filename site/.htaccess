# 1.To use URL Alias you need to be running apache with mod_rewrite enabled.

# 2. In your opencart directory rename htaccess.txt to .htaccess.

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteCond %{HTTP_HOST} ^reduktory\.fortuneprom\.kz$ [NC]
RewriteRule ^(.*)$ https://fortuneprom.kz/reduktory? [R=301,L]

RedirectMatch 404 ^/codex_bly_bld_card_fix_20260717\.php$
RedirectMatch 404 ^/codex_clear_bly_bld_cache_20260717\.php$

# For any support issues please visit: http://www.opencart.com

Options +FollowSymlinks

# Prevent Directory listing
Options -Indexes

# Security headers
<IfModule mod_headers.c>
	Header always set X-Content-Type-Options "nosniff"
	Header always set X-Frame-Options "SAMEORIGIN"
	Header always set X-XSS-Protection "1; mode=block"
	Header always set Referrer-Policy "strict-origin-when-cross-origin"
	# AI agent discovery (RFC 8288)
	Header always set Link "</.well-known/api-catalog>; rel=\"api-catalog\", </.well-known/agent-skills/index.json>; rel=\"service-doc\", </.well-known/mcp/server-card.json>; rel=\"service-desc\", </auth.md>; rel=\"describedby\", </.well-known/acp.json>; rel=\"acp\", </.well-known/ucp>; rel=\"ucp\""
	SetEnvIfNoCase Request_URI "^/admin(/|$)" fp_admin_no_cache=1
	Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0" env=fp_admin_no_cache
	Header always set Pragma "no-cache" env=fp_admin_no_cache
	Header always set Expires "Thu, 01 Jan 1970 00:00:00 GMT" env=fp_admin_no_cache
</IfModule>

# Prevent Direct Access to files
<FilesMatch "(?i)((\.tpl|.twig|\.ini|\.log|(?<!robots)\.txt))">
	Require all denied
</FilesMatch>

# SEO URL Settings
RewriteEngine On
RewriteBase /

# Block temporary Codex maintenance helpers even if PHP opcache still has them.
RewriteRule ^_codex_.*\.php$ - [R=404,L]
RewriteRule ^codex_bly_bld_(card_fix|clear)_20260717\.php$ - [R=404,L]

# 301 Redirects: fix broken category URLs
RewriteRule ^electrodvigateli/?$ https://fortuneprom.kz/elektrodvigateli [R=301,L]
RewriteRule ^nasosnoe-oborudovanie/?$ https://fortuneprom.kz/nasosy [R=301,L]
RewriteRule ^promyshlennye-generatory/?$ https://fortuneprom.kz/generatory [R=301,L]

# 301 Redirects: NMRV 050-40 product canonicalization
RewriteRule ^nmrv-050-40-0-37-1500-b5-v3/?$ https://fortuneprom.kz/reduktory/chervyachnye/nmrv/nmrv-050/nmrv-050-40-0-37-1500-b5-v3? [R=301,L]
RewriteRule ^reduktory/chervyachnye/nmrv/nmrv-050/nmrv-050-40-037-1500-b5-b3/?$ https://fortuneprom.kz/reduktory/chervyachnye/nmrv/nmrv-050/nmrv-050-40-0-37-1500-b5-v3? [R=301,L]
RewriteCond %{THE_REQUEST} \s/+((reduktory/)?nmrv-050-40-0-37-1500-b5-(%D0%B2|%D0%92)3)[?\s] [NC]
RewriteRule ^ https://fortuneprom.kz/reduktory/chervyachnye/nmrv/nmrv-050/nmrv-050-40-0-37-1500-b5-v3? [R=301,L]
