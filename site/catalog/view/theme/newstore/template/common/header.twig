<script>
(function () {
  var nodes = document.body.childNodes;
  for (var i = nodes.length - 1; i >= 0; i--) {
    if (nodes[i].nodeType === 3 && nodes[i].nodeValue.indexOf('\uFEFF') !== -1) {
      document.body.removeChild(nodes[i]);
    }
  }
})();
</script>
