<script>
document.addEventListener("click", function(e) {
  var btn = e.target.closest(".product-thumb .btn-wishlist");
  if (btn) {
    e.preventDefault();
    e.stopPropagation();
    var thumb = btn.closest(".product-thumb");
    var titleEl = thumb.querySelector(".product-name a");
    var title = titleEl ? titleEl.textContent.trim() : "";
    var url = "https://wa.me/77775887716?text=" + encodeURIComponent("Здравствуйте! Интересует цена на товар: " + title);
    window.open(url, "_blank");
  }
});
</script>
<script>
window.addEventListener("scroll", function() {
  if (window.scrollY > 40) {
