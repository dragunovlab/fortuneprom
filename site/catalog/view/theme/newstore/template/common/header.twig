  justify-content: center !important; margin-right: 12px !important; border-radius: 8px !important;
  background: #f1f5f9 !important; color: #2563eb !important; font-size: 14px !important; flex-shrink: 0 !important;
}
.fp-catalog-drawer-panel .toggle-child {
  position: absolute !important; top: 10px !important; right: 16px !important; width: 36px !important; height: 36px !important;
  display: flex !important; align-items: center !important; justify-content: center !important;
  border-radius: 8px !important; background: #f1f5f9 !important; color: #64748b !important; cursor: pointer !important;
}
.fp-catalog-drawer-panel .toggle-child:hover { background: #e2e8f0 !important; color: #0f172a !important; }
.fp-catalog-drawer-panel .ns-dd {
  display: none !important; padding: 8px 24px 16px 68px !important; background: #f8fafc !important; border-top: 1px solid #e2e8f0 !important;
}
.fp-catalog-drawer-panel > li > .toggle-child.open ~ .ns-dd { display: block !important; }
.fp-catalog-drawer-panel .ns-dd li { list-style: none !important; margin: 6px 0 !important; }
.fp-catalog-drawer-panel .ns-dd li > a { color: #475569 !important; font-weight: 500 !important; font-size: 13.5px !important; text-decoration: none !important; }
.fp-catalog-drawer-panel .ns-dd li > a:hover { color: #2563eb !important; }
</style>
</head>
