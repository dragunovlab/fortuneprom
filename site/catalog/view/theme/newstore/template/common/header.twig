<div id="login-form-popup" class="modal fade" role="dialog">
	<div class="modal-dialog modal-login">
		<div class="modal-content">
			<form>
				<div class="modal-header">
					<button type="button" class="close" data-dismiss="modal">&times;</button>
					<h4 class="modal-title">{{ text_login }}</h4>
				</div>
				<div class="modal-body">
				<div class="form-group">
					<div class="message"></div>
				</div>
					<div class="form-group">
						<div class="input-group">
							<span class="input-group-addon"><i class="fa fa-envelope"></i></span>
							<input type="text" name="emailpopup" value="" placeholder="{{ entry_email|replace({ (':'): '' }) }}" id="input-email-popup" class="form-control" autocomplete="username" />
						</div>
					</div>
					<div class="form-group">
						<div class="input-group">
							<span class="input-group-addon"><i class="fa fa-lock"></i></span>
							<input type="password" name="passwordpopup" value="" placeholder="{{ entry_password|replace({ (':'): '' }) }}" id="input-password-popup" class="form-control" autocomplete="current-password" />
						</div>
					</div>
					<div class="form-group text-center">
						<a href="{{ register }}">{{ text_register }}</a> | <a href="{{ forgotten }}">{{ text_forgotten }}</a>
					</div>
				</div>
				<div class="modal-footer">
					<input type="button" value="{{ button_login }}" id="button-login-popup" class="btn-login btn-block" />
				</div>
			</form>
		</div>
	</div>
</div>
